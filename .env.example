# Chave da API do Google AI Studio
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# System Prompt real (vive no repo privado mynutri-core)
MYNUTRI_SYSTEM_PROMPT=

# URL pública do projeto
NEXT_PUBLIC_APP_URL=

# Upstash/Vercel KV — rate limiting
# Vercel KV (Redis) — provisionar via Vercel Integrations → Upstash Redis
# Documentação: https://vercel.com/marketplace?category=storage&search=redis
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=
