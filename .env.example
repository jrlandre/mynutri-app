# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chave da API do Google AI Studio
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# System Prompt real (vive no repo privado mynutri-core)
MYNUTRI_SYSTEM_PROMPT=

# URL pública do app (ex: https://mynutri.food) — usada para montar subdomínios e URLs
NEXT_PUBLIC_APP_URL=

# Painel da nutricionista — sobrescreve detecção de subdomínio em dev local
# Ex: PAINEL_DEV_SUBDOMAIN=ana → acessa /painel como se fosse ana.mynutri.pro
PAINEL_DEV_SUBDOMAIN=

# Upstash/Vercel KV — rate limiting
# Vercel KV (Redis) — provisionar via Vercel Integrations → Upstash Redis
# Documentação: https://vercel.com/marketplace?category=storage&search=redis
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=

# Stripe — assinaturas de nutricionistas
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
